<IfModule mod_rewrite.c>
    # Enable Rewrite Engine
    RewriteEngine On
    RewriteBase /

    # 1. Externally redirect /file.php to /file
    # This prevents users from accessing the .php version directly.
    RewriteCond %{THE_REQUEST} "^[A-Z]{3,9}\ /([^/.]+)\.php\ HTTP/" [NC]
    RewriteRule ^(.+)\.php$ /%1 [R=301,L,NE]

    # 2. Internally rewrite /file to /file.php
    # This allows the app to load file.php when /file is requested.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [L]
</IfModule>
